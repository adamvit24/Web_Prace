@{
    ViewData["Title"] = "Restaurace U Arouše";
}

<div class="container">
    <section class="hero">
        <h1>Restaurace U Arouše</h1>
        <p>Fine dining zážitek, kde se tradice setkává s moderní gastronomií.</p><br>
        <p>Vítejte v prostoru, kde se každé jídlo stává uměleckým dílem a každý detail má svůj význam.</p>
    </section>

    <section>
        <h2>O nás</h2>
        <p>
            Restaurace U Arouše představuje vrchol současné české gastronomie.
            Naše kuchyně propojuje tradiční receptury s moderními kulinářskými technikami.
            Každý pokrm je výsledkem precizní práce našeho šéfkuchaře a jeho týmu.
            Pracujeme výhradně s prvotřídními sezónními surovinami od lokálních farmářů.
            Důraz klademe na harmonii chutí, textur i vizuální prezentaci.
            Naše degustační menu je pečlivě sestavené tak, aby vytvořilo dokonalý gastronomický příběh.
            Interiér restaurace nabízí elegantní a intimní prostředí pro výjimečné chvíle.
            Someliér pro vás vybírá vína z prestižních světových vinařství.
            Každá návštěva je pro nás osobním závazkem k dokonalosti.
            Naším cílem je vytvořit nezapomenutelný zážitek, který přesahuje běžné stolování.
        </p>
        <img src="/obrazky1/obr2.png" alt="Interiér restaurace" class="content-img">

        <h3>Proč k nám přijít?</h3>
        <ul>
            <li>Degustační menu inspirované sezónními surovinami</li>
            <li>Exkluzivní výběr archivních a světových vín</li>
            <li>Individuální přístup a dokonalý servis</li>
        </ul>

        <img src="/obrazky1/obr3.png" alt="Interiér restaurace" class="content-img">
    </section>
</div>