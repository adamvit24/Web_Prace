@{
    ViewData["Title"] = "Přihlášení";
}

<style>
    .submit-btn {
        background-color: #fff;
        border: 2px solid #333;
        color: #333;
        padding: 10px 20px;
        cursor: pointer;
        font-size: 16px;
        font-weight: bold;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    .submit-btn:hover {
        background-color: #ffcc00;
        color: #fff;
        border-color: #ffcc00;
    }

    label {
        display: block;
        margin-bottom: 5px;
    }
</style>

<div class="container">
    <h1>Přihlášení</h1>
    <form asp-action="Login" method="post" style="max-width: 400px; margin: 30px 0;">
        <div style="margin-bottom: 15px;">
            <label for="jmeno">Jméno:</label>
            <input type="text" id="jmeno" name="jmeno" required>
        </div>

        <div style="margin-bottom: 20px;">
            <label for="heslo">Heslo:</label>
            <input type="password" id="heslo" name="heslo" required>
        </div>

        <button type="submit" class="submit-btn">Přihlásit se</button>
    </form>
    <p>Nemáte účet? <a asp-action="Register" asp-controller="User">Zaregistrujte se</a></p>
</div>