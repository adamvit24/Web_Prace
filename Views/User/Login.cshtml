@{
    ViewData["Title"] = "Přihlášení";
}

<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <title>Přihlášení - Restaurace U Arouše</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .submit-btn {
            background-color: #fff;
            border: 2px solid #333;
            color: #333;
            padding: 10px 20px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            border-radius: 4px;
            transition: all 0.3s ease;
        }

        .submit-btn:hover {
            background-color: #ffcc00;
            color: #fff;
            border-color: #ffcc00;
        }

        label {
            display: block;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>

    <header>
        <div class="container header-flex">
            <img src="/obrazky1/Logo.jpg" alt="Logo Restaurace U Arouše" class="logo">

            <nav>
                <ul class="menu">
                    <li><a asp-action="Index" asp-controller="Home">Úvod</a></li>
                    <li><a asp-action="Menu" asp-controller="Home">Menu</a></li>
                    <li><a asp-action="Privacy" asp-controller="Home">Kontakt</a></li>
                    <li><a asp-action="Register" asp-controller="User">Registrace</a></li>
                    <li><a asp-action="Login" asp-controller="User" class="active">Přihlášení</a></li>
                    <li><a asp-action="Dashboard" asp-controller="User">Profil</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="container">
        <h1>Přihlášení</h1>
        <form asp-action="Login" method="post" style="max-width: 400px; margin: 30px auto;">
            <div style="margin-bottom: 15px;">
                <label for="jmeno">Jméno:</label>
                <input type="text" id="jmeno" name="jmeno" required>
            </div>

            <div style="margin-bottom: 20px;">
                <label for="heslo">Heslo:</label>
                <input type="password" id="heslo" name="heslo" required>
            </div>

            <button type="submit" class="submit-btn">Přihlásit se</button>
        </form>
        <p>Nemáte účet? <a asp-action="Register" asp-controller="User">Zaregistrujte se</a></p>
    </main>

    <footer>
        <div class="container">
            <p>© 2026 Restaurace U Arouše</p>
            <p>
                <a href="#">Instagram</a> |
                <a href="#">Facebook</a>
            </p>
        </div>
    </footer>

</body>
</html>