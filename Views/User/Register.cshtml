@{
    ViewData["Title"] = "Registrace";
}

<style>
    .submit-btn {
        background-color: #fff;
        border: 2px solid #333;
        color: #333;
        padding: 10px 20px;
        cursor: pointer;
        font-size: 16px;
        font-weight: bold;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    .submit-btn:hover {
        background-color: #ffcc00;
        color: #fff;
        border-color: #ffcc00;
    }

    label {
        display: block;
        margin-bottom: 5px;
    }
</style>

<div class="container">
    <h1>Registrace</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div style="background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 4px; padding: 15px; margin: 20px 0; color: #721c24;">
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <p>@error.ErrorMessage</p>
                }
            }
        </div>
    }

    <form asp-action="Register" method="post" style="max-width: 400px; margin: 30px 0;">
        <div style="margin-bottom: 15px;">
            <label for="jmeno">Jméno:</label>
            <input type="text" id="jmeno" name="jmeno" required>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="heslo">Heslo:</label>
            <input type="password" id="heslo" name="heslo" required>
        </div>

        <div style="margin-bottom: 20px;">
            <label for="heslo2">Potvrzení hesla:</label>
            <input type="password" id="heslo2" name="heslo2" required>
        </div>

        <button type="submit" class="submit-btn">Zaregistrovat se</button>
    </form>
    <p>Už máte účet? <a asp-action="Login" asp-controller="User">Přihlaste se</a></p>
</div>
