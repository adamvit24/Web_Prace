@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .submit-btn {
        background-color: #fff;
        border: 2px solid #333;
        color: #333;
        padding: 10px 20px;
        cursor: pointer;
        font-size: 16px;
        font-weight: bold;
        border-radius: 4px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .submit-btn:hover {
        background-color: #ffcc00;
        color: #fff;
        border-color: #ffcc00;
    }
</style>

<div class="container">
    @if (ViewData["Jmeno"] != null)
    {
        <div style="background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 4px; padding: 15px; margin: 20px 0; text-align: center;">
            <h2 style="color: #155724; margin-top: 0;">Úspěšně jste se přihlásili pod účtem <strong>@ViewData["Jmeno"]</strong></h2>
            <p style="color: #155724;">Vítej mezi Námi!</p>
        </div>
    }

    <h1>Váš profil</h1>

    <p>
        <a asp-action="Logout" asp-controller="User" class="submit-btn">Odhlásit se</a>
    </p>
</div>
