<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web_prace</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web_prace.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="container header-flex">
            <img src="@(Url.Content("~/obrazky1/Logo.jpg"))" alt="Logo Restaurace U Arouše" class="logo" />

            <nav>
                <ul class="menu">
                    <li><a asp-controller="Home" asp-action="Index">Úvod</a></li>
                    <li><a asp-controller="Home" asp-action="Menu">Menu</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Kontakt</a></li>
                    <li><a asp-controller="User" asp-action="Register">Registrace</a></li>
                    <li><a asp-controller="User" asp-action="Login">Přihlášení</a></li>
                    <li><a asp-controller="User" asp-action="Dashboard">Profil</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <p>© 2026 Restaurace U Arouše</p>
            <p>
                <a href="#">Instagram</a> |
                <a href="#">Facebook</a>
            </p>
        </div>
    </footer>

</body>
</html>
